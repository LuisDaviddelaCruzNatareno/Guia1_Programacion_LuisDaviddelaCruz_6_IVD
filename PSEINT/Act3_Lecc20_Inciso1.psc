Algoritmo Act3_Lecc20_Inciso1
	Definir dia Como Real
	
	Escribir "Digite un número del 1 al 7: "
	Leer dia
	
	Segun dia Hacer
		1,2,3,4,5:
			Escribir "Análisis del día ---> "
			Escribir "Entre Semana"
		6,7:
			Escribir "Análisis del día ---> "
			Escribir "Fin de Semana"
		De Otro Modo:
			Escribir "Ese día no existe!!"
	Fin Segun
FinAlgoritmo
